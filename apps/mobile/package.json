{
  "name": "@pronunciation-mirror/mobile",
  "version": "0.1.1",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start --dev-client",
    "ios": "expo start --dev-client --ios",
    "ios:prebuild": "expo prebuild --platform ios",
    "eas:configure": "npx eas-cli@latest update:configure",
    "eas:build:staging": "npx eas-cli@latest build --platform ios --profile staging",
    "eas:submit:staging": "npx eas-cli@latest submit --platform ios --profile staging --latest",
    "eas:update:staging": "npx eas-cli@latest update --channel staging --environment preview",
    "lint": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "build": "expo config --type public > /dev/null"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "azure-pronunciation-stream": "file:modules/azure-pronunciation-stream",
    "expo": "~57.0.4",
    "expo-application": "~57.0.0",
    "expo-audio": "^57.0.0",
    "expo-crypto": "~57.0.0",
    "expo-dev-client": "57.0.5",
    "expo-file-system": "~57.0.0",
    "expo-network": "~57.0.0",
    "expo-notifications": "~57.0.3",
    "expo-secure-store": "~57.0.0",
    "expo-sharing": "~57.0.3",
    "expo-updates": "~57.0.6",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-purchases": "^10.4.1",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "typescript": "6.0.3"
  }
}
