# Expo client: Supabase project URL; get from Supabase local `supabase status` or hosted project settings; client-side public.
EXPO_PUBLIC_SUPABASE_URL=

# Expo client: Supabase anon key; get from Supabase local `supabase status` or hosted project API settings; client-side public.
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Expo client: Next.js API base URL; set to local API URL in development or deployed API URL in production; client-side public.
EXPO_PUBLIC_API_BASE_URL=

# Expo client: RevenueCat iOS public SDK key; get from RevenueCat project app settings; client-side public.
EXPO_PUBLIC_REVENUECAT_IOS_PUBLIC_SDK_KEY=

# Server: Supabase project URL; get from Supabase local `supabase status` or hosted project settings; server-side.
SUPABASE_URL=

# Server: Supabase anon key; get from Supabase local `supabase status` or hosted project API settings; server-side.
SUPABASE_ANON_KEY=

# Server: Supabase service role key; get from Supabase local `supabase status` or hosted project API settings; server-side secret.
SUPABASE_SERVICE_ROLE_KEY=

# Server: Azure Speech resource key for Pronunciation Assessment; get from Azure Portal Speech resource Keys and Endpoint; server-side secret.
AZURE_SPEECH_KEY=

# Server: Azure Speech resource region, for example `japaneast` or `eastus`; get from Azure Portal Speech resource; server-side.
AZURE_SPEECH_REGION=
# Server: Pronunciation Assessment locale. en-US enables the full IPA/prosody capability set.
AZURE_SPEECH_LOCALE=en-US

# Server: Azure assessment mode; use `auto` for real Azure when keys are set, `mock` for local mock, or `fail` for failure tests; server-side.
AZURE_ASSESSMENT_MODE=auto

# Server: OpenAI API key for rare-case advice generation; get from OpenAI platform project API keys; server-side secret.
OPENAI_API_KEY=

# Server: OpenAI model for short advice generation; choose latest stable at implementation time; server-side.
OPENAI_ADVICE_MODEL=

# Server: RevenueCat secret API key; get from RevenueCat project API keys; server-side secret.
REVENUECAT_SECRET_KEY=

# Server: RevenueCat webhook authorization token; configure in RevenueCat webhook settings; server-side secret.
REVENUECAT_WEBHOOK_AUTH_TOKEN=

# Server: RevenueCat Pro entitlement identifier, expected `pro`; configure in RevenueCat entitlements; server-side.
REVENUECAT_PRO_ENTITLEMENT_ID=pro

# Server: Monthly iOS subscription product identifier; configure in App Store Connect and RevenueCat; server-side.
IAP_IOS_MONTHLY_PRODUCT_ID=

# Server: Annual iOS subscription product identifier; configure in App Store Connect and RevenueCat; server-side.
IAP_IOS_ANNUAL_PRODUCT_ID=

# Server: Python inference service base URL; set to local container URL or deployed service URL; server-side.
PYTHON_SERVICE_URL=

# Server: Shared API key used by Next.js API to call Python inference service; generate locally; server-side secret.
PYTHON_SERVICE_API_KEY=

# Server: Piper voice identifier for US English; configure from installed Piper voice package; server-side.
PIPER_VOICE_US=en_US-lessac-medium

# Server: Directory or mounted path where Piper voice files are available; configure in Python service environment; server-side.
PIPER_VOICE_DIR=runtime/piper/voices/en_US-lessac-medium

# Server: Supabase Storage bucket for generated coach TTS cache; create in Supabase; server-side.
TTS_CACHE_BUCKET=

# Staging: hosted Supabase project ref; used by staging deployment/setup scripts; do not use production project.
STAGING_SUPABASE_PROJECT_REF=

# Staging: hosted Supabase project URL; staging-only.
STAGING_SUPABASE_URL=

# Staging: hosted Supabase anon key; staging-only.
STAGING_SUPABASE_ANON_KEY=

# Staging: hosted Supabase service role key; staging-only secret.
STAGING_SUPABASE_SERVICE_ROLE_KEY=

# Staging: hosted Supabase Postgres connection string for migration/seed; staging-only secret.
STAGING_SUPABASE_DB_URL=

# Server: Signed URL TTL seconds for coach TTS playback; choose implementation value; server-side.
TTS_SIGNED_URL_TTL_SECONDS=3600

# Server: Daily soft cap for Pro free-text assessments; product default is 20; server-side.
FREE_TEXT_DAILY_SOFT_CAP=20

# Server: App environment name, for example `local`, `staging`, or `production`; server-side.
APP_ENV=local

# Server: Public app version used in logs when unavailable from client; server-side.
APP_VERSION=
